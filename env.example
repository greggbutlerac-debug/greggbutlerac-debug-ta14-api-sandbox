# TA-14 API Sandbox environment example
TA14_MODE=sandbox

# Rate limiting is enabled for POST /v1/* evaluation routes only.
TA14_RATE_LIMIT_ENABLED=true
TA14_ANON_HOURLY_LIMIT=5
TA14_ANON_DAILY_LIMIT=20
TA14_KEY_MONTHLY_LIMIT=100

# Persistent usage storage. Set this to the Internal Redis URL from Render Key Value.
# TA14_REDIS_URL=redis://...

# Optional legacy paid/partner key.
# TA14_API_KEY=replace-me
# TA14_LEGACY_KEY_PLAN=partner
# TA14_LEGACY_KEY_MONTHLY_LIMIT=5000

# Optional multi-key registry. Keep this in Render environment variables, never in GitHub.
# TA14_API_KEYS_JSON=[{"key":"replace-me","name":"Developer A","plan":"developer_free","monthly_limit":100,"active":true}]

TA14_AUDIT_LOG=false
TA14_AUDIT_LOG_PATH=./ta14_audit_log.jsonl
TA14_MAX_BODY_BYTES=65536
CORS_ALLOW_ORIGINS=*
