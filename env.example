# TA-14 API Sandbox environment example

TA14_MODE=sandbox

# Optional API key protection.
# If set, protected POST endpoints require the request header:
# X-API-Key: your-key-here
# TA14_API_KEY=replace-me

# Optional sandbox rate limiting.
TA14_RATE_LIMIT_ENABLED=true
TA14_RATE_LIMIT_MAX=60
TA14_RATE_LIMIT_WINDOW_SECONDS=60

# Optional audit logging.
TA14_AUDIT_LOG=false
TA14_AUDIT_LOG_PATH=./ta14_audit_log.jsonl

# Request body size limit.
TA14_MAX_BODY_BYTES=200000

# CORS origins.
# Use "*" for open sandbox mode.
# For production, set this to your site origin, for example:
# CORS_ALLOW_ORIGINS=https://ta14-architecture.netlify.app
CORS_ALLOW_ORIGINS=*
